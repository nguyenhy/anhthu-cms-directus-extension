{
	"name": "frontstore_bundle",
	"description": "Please enter a description for your extension",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-bundle"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "bundle",
		"path": {
			"app": "dist/app.js",
			"api": "dist/api.js"
		},
		"entries": [
			{
				"type": "endpoint",
				"name": "frontstore",
				"source": "src/frontstore_api_endpoint/index.ts"
			},
			{
				"type": "hook",
				"name": "webhook",
				"source": "src/frontstore_hook/index.ts"
			}
		],
		"host": "^10.10.0"
	},
	"scripts": {
		"test": "tsc --noEmit",
		"build": "directus-extension build",
		"dev": "CHOKIDAR_USEPOLLING=true directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"add": "directus-extension add"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "18.0.0",
		"@types/node": "^26.0.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1071.0",
		"@aws-sdk/s3-request-presigner": "^3.1071.0",
		"liquidjs": "10.26.0",
		"nanoid": "^5.1.14",
		"resend": "^6.14.0"
	},
	"allowScripts": {
		"esbuild@0.26.0": true,
		"esbuild@0.27.7": true,
		"fsevents@2.3.3": true,
		"vue-demi@0.14.10": true
	}
}
